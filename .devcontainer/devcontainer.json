{
  "name": "AgenticPay",
  "dockerComposeFile": "docker-compose.yml",
  "service": "devcontainer",
  "workspaceFolder": "/workspaces/agenticpay",
  "remoteUser": "node",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "username": "node"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22",
      "nodeGypDependencies": true
    },
    "ghcr.io/devcontainers/features/rust:1": {
      "version": "stable",
      "profile": "minimal"
    },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest"
    }
  },
  "containerEnv": {
    "NODE_ENV": "development",
    "DATABASE_URL": "postgresql://postgres:postgres@postgres:5432/agenticpay",
    "REDIS_URL": "redis://redis:6379",
    "REDIS_ENABLED": "true",
    "PORT": "3001",
    "OPENAI_API_KEY": "sk-dev-placeholder-replace-me",
    "JOBS_ENABLED": "false",
    "QUEUE_ENABLED": "false",
    "CORS_ALLOWED_ORIGINS": "*"
  },
  "forwardPorts": [3000, 3001, 5432, 6379],
  "portsAttributes": {
    "3000": { "label": "Frontend", "onAutoForward": "notify" },
    "3001": { "label": "Backend API", "onAutoForward": "silent" },
    "5432": { "label": "PostgreSQL", "onAutoForward": "ignore" },
    "6379": { "label": "Redis", "onAutoForward": "ignore" }
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "postStartCommand": "bash .devcontainer/post-start.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "ms-playwright.playwright",
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",
        "Prisma.prisma",
        "redhat.vscode-yaml",
        "42Crunch.vscode-openapi",
        "ms-azuretools.vscode-docker",
        "github.vscode-github-actions"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "typescript.tsdk": "node_modules/typescript/lib",
        "rust-analyzer.checkOnSave.command": "clippy"
      }
    }
  },
  "mounts": [
    "source=${localWorkspaceFolder},target=/workspaces/agenticpay,type=bind,consistency=cached"
  ]
}
