{
  "name": "@agenticpay/api-hooks-generator",
  "version": "0.1.0",
  "description": "Generate type-safe API client hooks from OpenAPI spec",
  "main": "dist/index.js",
  "bin": {
    "generate-api-hooks": "./dist/cli.js"
  },
  "scripts": {
