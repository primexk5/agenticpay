    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@agenticpay/typescript-config": "*",
    "@agenticpay/eslint-config": "*",
    "@types/node": "^22.5.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.1"
  },
  "publishConfig": {
    "access": "public"
  }
