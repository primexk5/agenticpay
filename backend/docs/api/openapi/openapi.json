    "/onboarding/{id}/documents": {
      "post": {
        "tags": [
          "Onboarding"
        ],
        "summary": "Submit onboarding document",
        "operationId": "POST_/onboarding/{id}/documents",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "taskId": {
                    "type": "string",
                    "minLength": 1
                  },
                  "documentType": {
                    "type": "string",
                    "enum": [
                      "business_license",
                      "tax_id",
                      "bank_statement",
                      "identity_proof",
                      "address_proof"
                    ]
                  },
                  "fileName": {
                    "type": "string",
                    "minLength": 1
                  },
                  "fileSize": {
                    "type": "number",
                    "minimum": 0
                  },
                  "mimeType": {
                    "type": "string",
                    "minLength": 1
                  },
                  "fileData": {
                    "type": "string"
                  }
                },
                "required": [
                  "taskId",
                  "documentType",
                  "fileName",
                  "fileSize",
                  "mimeType"
                ]
              },
              "examples": {
                "default": {
                  "summary": "Example request",
                  "value": {
                    "taskId": "string",
                    "documentType": "business_license",
                    "fileName": "string",
                    "fileSize": 1,
                    "mimeType": "string",
                    "fileData": "string"
                  }
                }
              }
            }
