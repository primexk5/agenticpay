    "/escrow": {
      "post": {
        "tags": [
          "Escrow"
        ],
        "summary": "Create escrow agreement",
        "operationId": "POST_/escrow",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "projectId": {
                    "type": "string",
                    "minLength": 1
                  },
                  "payerId": {
                    "type": "string",
                    "minLength": 1
                  },
                  "payeeId": {
                    "type": "string",
                    "minLength": 1
                  },
                  "currency": {
                    "type": "string",
                    "minLength": 1
                  },
                  "totalAmount": {
                    "type": "number",
                    "minimum": 0
                  },
                  "milestones": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "title": {
                          "type": "string",
                          "minLength": 1
                        },
                        "description": {
                          "type": "string"
                        },
                        "amount": {
                          "type": "number",
                          "minimum": 0
                        },
                        "completionCriteria": {
                          "type": "string",
                          "minLength": 1
                        }
                      },
                      "required": [
                        "title",
                        "amount",
                        "completionCriteria"
                      ]
                    }
                  },
                  "metadata": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "string"
                    }
                  }
                },
                "required": [
                  "projectId",
                  "payerId",
                  "payeeId",
                  "currency",
                  "totalAmount",
                  "milestones"
                ]
              },
              "examples": {
                "default": {
                  "summary": "Example request",
                  "value": {
                    "projectId": "string",
                    "payerId": "string",
                    "payeeId": "string",
                    "currency": "string",
                    "totalAmount": 1,
                    "milestones": [
                      {
                        "title": "string",
                        "description": "string",
                        "amount": 1,
                        "completionCriteria": "string"
                      }
                    ],
                    "metadata": {}
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
